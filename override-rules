// 工具函数
function parseBoolean(value) {
  if (typeof value === "boolean") return value;
  if (typeof value === "string") return value.toLowerCase() === "true" || value === "1";
  return false;
}

function parseIntSafe(value, defaultValue = 0) {
  if (value === null || typeof value === "undefined") return defaultValue;
  const parsed = parseInt(String(value), 10);
  return isNaN(parsed) ? defaultValue : parsed;
}

function flattenAndFilter(array) {
  return array.flat().filter(Boolean);
}

// 解析参数
function parseArguments(args = {}) {
  const paramMap = {
    loadbalance: "loadBalance",
    landing: "landing",
    ipv6: "ipv6Enabled",
    full: "fullConfig",
    keepalive: "keepAliveEnabled",
    fakeip: "fakeIPEnabled",
    quic: "quicEnabled",
    regex: "regexFilter"
  };

  const config = { ...DEFAULT_CONFIG, countryThreshold: 0 };

  for (const [param, configKey] of Object.entries(paramMap)) {
    const value = args[param];
    if (value === null || typeof value === "undefined") {
      config[configKey] = DEFAULT_CONFIG[configKey];
    } else {
      config[configKey] = parseBoolean(value);
    }
  }

  config.countryThreshold = parseIntSafe(args.threshold, 0);
  return config;
}

// 创建国家代理组
function createCountryProxyGroups({ countries, landing, loadBalance, regexFilter, countryInfo }) {
  const groups = [];
  const groupType = loadBalance ? "load-balance" : "url-test";
  
  const proxyMap = regexFilter ? null : Object.fromEntries(
    countryInfo.map(item => [item.country, item.nodes])
  );

  for (const country of countries) {
    const countryConfig = COUNTRY_INFO[country];
    if (!countryConfig) continue;

    const group = {
      name: `${country}节点`,
      icon: countryConfig.icon,
      type: groupType,
      url: "https://cp.cloudflare.com/generate_204",
      interval: 60,
      tolerance: 20,
      ...(loadBalance && { strategy: "sticky-sessions" })
    };

    if (regexFilter) {
      Object.assign(group, {
        "include-all": true,
        filter: countryConfig.pattern,
        "exclude-filter": landing ? `${LANDING_PATTERN}|${LOW_RATE_PATTERN}` : LOW_RATE_PATTERN
      });
    } else {
      const proxies = proxyMap?.[country] || [];
      Object.assign(group, { proxies });
    }

    groups.push(group);
  }

  return groups;
}

// 识别低倍率节点
function identifyLowRateNodes(proxies) {
  const lowRatePattern = new RegExp(LOW_RATE_PATTERN, "i");
  return (proxies || [])
    .filter(proxy => lowRatePattern.test(proxy.name || ""))
    .map(proxy => proxy.name)
    .filter(name => !!name);
}

// 分类节点
function categorizeNodes(proxies) {
  const landingPattern = new RegExp(LANDING_PATTERN, "i");
  const lowRatePattern = new RegExp(LOW_RATE_PATTERN, "i");
  
  const landingNodes = [];
  const nonLandingNodes = [];

  for (const proxy of proxies || []) {
    const name = proxy.name || "";
    if (landingPattern.test(name)) {
      landingNodes.push(name);
    } else if (!lowRatePattern.test(name)) {
      nonLandingNodes.push(name);
    }
  }

  return { landingNodes, nonLandingNodes };
}

// 按国家分类节点
function classifyByCountry(proxies) {
  const countryMap = {};
  const nodes = proxies || [];
  
  for (const node of nodes) {
    const name = node.name || "";
    if (!name) continue;
    
    // 检查是否为落地节点或低倍率节点
    if (new RegExp(LANDING_PATTERN, "i").test(name) || new RegExp(LOW_RATE_PATTERN, "i").test(name)) {
      continue;
    }
    
    // 按国家分类
    for (const [country, config] of Object.entries(COUNTRY_INFO)) {
      if (new RegExp(config.pattern.replace(/^\(\?i\)/, ""), "i").test(name)) {
        if (!countryMap[country]) {
          countryMap[country] = [];
        }
        countryMap[country].push(name);
        break;
      }
    }
  }

  return Object.entries(countryMap).map(([country, nodes]) => ({
    country,
    nodes
  }));
}

// 过滤并排序国家
function filterAndSortCountries(countryData, threshold) {
  const filtered = countryData.filter(item => item.nodes.length >= threshold);
  
  filtered.sort((a, b) => {
    const weightA = COUNTRY_INFO[a.country]?.weight ?? Infinity;
    const weightB = COUNTRY_INFO[b.country]?.weight ?? Infinity;
    return weightA - weightB;
  });

  return filtered.map(item => item.country + "节点");
}

// 移除"节点"后缀
function removeNodeSuffix(names) {
  const suffixRegex = new RegExp(`${"节点"}$`);
  return names.map(name => name.replace(suffixRegex, ""));
}

