      name: GROUP_NAMES.SSH,
      icon: `${CDN_BASE}/gh/Koolson/Qure@master/IconSet/Color/Server.png`,
      type: "select",
      proxies: defaultProxies
    },
    {
      name: GROUP_NAMES.SOGOU_INPUT,
      icon: `${CDN_BASE}/gh/powerfullz/override-rules@master/icons/Sougou.png`,
      type: "select",
      proxies: [GROUP_NAMES.DIRECT, "REJECT"]
    },
    {
      name: GROUP_NAMES.DIRECT,
      icon: `${CDN_BASE}/gh/Koolson/Qure@master/IconSet/Color/Direct.png`,
      type: "select",
      proxies: ["DIRECT", GROUP_NAMES.SELECT]
    },
    {
      name: GROUP_NAMES.AD_BLOCK,
      icon: `${CDN_BASE}/gh/Koolson/Qure@master/IconSet/Color/AdBlack.png`,
      type: "select",
      proxies: ["REJECT", "REJECT-DROP", GROUP_NAMES.DIRECT]
    },
    ...(hasLowCostOrRegex ? [{
      name: GROUP_NAMES.LOW_COST,
      icon: `${CDN_BASE}/gh/Koolson/Qure@master/IconSet/Color/Lab.png`,
      type: "url-test",
      url: "https://cp.cloudflare.com/generate_204",
      interval: 60,
      tolerance: 20,
      ...(regexFilter ? {
        "include-all": true,
        filter: `(?:${LOW_RATE_PATTERN})`
      } : {
        proxies: lowCostNodes
      })
    }] : []),
    {
      name: GROUP_NAMES.AUTO,
      icon: `${CDN_BASE}/gh/Koolson/Qure@master/IconSet/Color/Auto.png`,
      type: "url-test",
      url: "https://cp.cloudflare.com/generate_204",
      proxies: defaultFallback,
      interval: 60,
      tolerance: 20
    },
    {
      name: GROUP_NAMES.FALLBACK,
      icon: `${CDN_BASE}/gh/Koolson/Qure@master/IconSet/Color/Available_1.png`,
      type: "fallback",
      url: "https://cp.cloudflare.com/generate_204",
      proxies: defaultFallback,
      interval: 60,
      tolerance: 20
    },
    ...countryProxyGroups
  ].filter(Boolean);

  groups.push({
    name: GROUP_NAMES.GLOBAL,
    icon: `${CDN_BASE}/gh/Koolson/Qure@master/IconSet/Color/Global.png`,
    "include-all": true,
    type: "select",
    proxies: groups.map(group => String(group.name))
  });

  return groups;
}

// 构建规则
function buildRules({ quicEnabled }) {
  let rules = [...RULES];
  if (quicEnabled) {
    rules.unshift("AND,((DST-PORT,443),(NETWORK,UDP)),REJECT");
  }
  return rules;
}

// 构建DNS配置
function buildDNSConfig({ mode, ipv6Enabled, fakeIpFilter }) {
  const config = {
    enable: true,
    ipv6: ipv6Enabled,
    "prefer-h3": true,
    "enhanced-mode": mode,
    "default-nameserver": ["119.29.29.29", "223.5.5.5"],
    nameserver: ["system", "223.5.5.5", "119.29.29.29", "180.184.1.1"],
    fallback: ["quic://dns0.eu", "https://dns.cloudflare.com/dns-query", "https://dns.sb/dns-query", "tcp://208.67.222.222", "tcp://8.26.56.2"],
    "proxy-server-nameserver": ["https://dns.alidns.com/dns-query", "tls://dot.pub"]
  };

  if (fakeIpFilter) {
    config["fake-ip-filter"] = fakeIpFilter;
  }

  return config;
}

// 构建默认代理组
function buildDefaultProxyGroups({ landing, lowCostNodes, countryGroupNames, nonLandingNodes, regexFilter }) {
  const hasLowCostOrRegex = lowCostNodes.length > 0 || regexFilter;
  const landingGroup = landing ? GROUP_NAMES.LANDING : null;
  
  const defaultProxies = flattenAndFilter([
    GROUP_NAMES.SELECT,
    landingGroup,
    countryGroupNames,
    hasLowCostOrRegex && GROUP_NAMES.LOW_COST,
    GROUP_NAMES.MANUAL,
    "DIRECT"
  ]);
  
  const defaultProxiesDirect = flattenAndFilter([
    GROUP_NAMES.DIRECT,
    landingGroup,
    countryGroupNames,
    hasLowCostOrRegex && GROUP_NAMES.LOW_COST,
    GROUP_NAMES.SELECT,
    GROUP_NAMES.MANUAL
  ]);
  
  const defaultSelector = flattenAndFilter([
    GROUP_NAMES.AUTO,
    GROUP_NAMES.FALLBACK,
    landingGroup,
    countryGroupNames,
    hasLowCostOrRegex && GROUP_NAMES.LOW_COST,
    GROUP_NAMES.MANUAL,
    "DIRECT"
  ]);
  
  const defaultFallback = flattenAndFilter([
    landingGroup,
    countryGroupNames,
    hasLowCostOrRegex && GROUP_NAMES.LOW_COST,
    GROUP_NAMES.MANUAL,
    "DIRECT"
  ]);
  
  const frontProxySelector = flattenAndFilter([
    countryGroupNames,
    "DIRECT",
    !regexFilter && nonLandingNodes
  ]);

  return {
    defaultProxies,
    defaultProxiesDirect,
    defaultSelector,
    defaultFallback,
    frontProxySelector
  };
}

// 主处理函数
function main(subscription) {
  try {
    const args = typeof $arguments !== 'undefined' ? $arguments : {};
    const config = parseArguments(args);

    const proxies = subscription.proxies || [];
    
    // 分析节点
    const countryData = classifyByCountry(proxies);
    const lowCostNodes = identifyLowRateNodes(proxies);
    const { landingNodes, nonLandingNodes } = config.landing ? categorizeNodes(proxies) : { landingNodes: [], nonLandingNodes: [] };
    
    // 过滤和排序国家
    const countryGroupNames = filterAndSortCountries(countryData, config.countryThreshold);
    const countryNames = removeNodeSuffix(countryGroupNames);
    
    // 构建默认代理组
    const {
      defaultProxies,
      defaultProxiesDirect,
      defaultSelector,
      defaultFallback,
      frontProxySelector
    } = buildDefaultProxyGroups({
      landing: config.landing,
      lowCostNodes,
      countryGroupNames,
      nonLandingNodes,
      regexFilter: config.regexFilter
    });
    
    // 创建国家代理组
    const countryProxyGroups = createCountryProxyGroups({
      countries: countryNames,
      landing: config.landing,
      loadBalance: config.loadBalance,
      regexFilter: config.regexFilter,
      countryInfo: countryData
    });
    
    // 创建主代理组
    const proxyGroups = createMainProxyGroups({
      landing: config.landing,
      regexFilter: config.regexFilter,
      countries: countryGroupNames,
      countryProxyGroups,
      lowCostNodes,
      landingNodes,
      defaultProxies,
      defaultProxiesDirect,
      defaultSelector,
      defaultFallback,
      frontProxySelector
    });
    
    // 构建规则
    const rules = buildRules({ quicEnabled: config.quicEnabled });
    
    // 构建结果对象
    const result = {
      proxies: subscription.proxies,
      "proxy-groups": proxyGroups,
      "rule-providers": RULE_SETS,
      rules,
      sniffer: SNIFFER_CONFIG,
      dns: config.fakeIPEnabled 
        ? buildDNSConfig({ mode: "fake-ip", ipv6Enabled: config.ipv6Enabled, fakeIpFilter: FAKE_IP_SKIP_DOMAINS }) 
        : buildDNSConfig({ mode: "redir-host", ipv6Enabled: config.ipv6Enabled }),
      "geodata-mode": true,
      "geox-url": GEO_DATA_SOURCES
    };
    
    // 如果启用完整配置，添加更多选项
    if (config.fullConfig) {
      Object.assign(result, {
        "mixed-port": 7890,
        "redir-port": 7892,
        "tproxy-port": 7893,
        "routing-mark": 7894,
        "allow-lan": true,
        "bind-address": "*",
        ipv6: config.ipv6Enabled,
        mode: "rule",
        "unified-delay": true,
        "tcp-concurrent": true,
        "find-process-mode": "off",
        "log-level": "info",
        "geodata-loader": "standard",
        "external-controller": ":9999",
        "disable-keep-alive": !config.keepAliveEnabled,
        profile: {
          "store-selected": true
        }
      });
    }
    
    return result;
  } catch (error) {
    console.error("[powerfullz 的覆写脚本] 处理出错:", error);
    return subscription;
  }
}

// 导出主函数
globalThis.main = main;
